{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Tracebloc Helm Chart Values",
  "type": "object",
  "required": ["jobsManager", "mysql", "clusterRole", "secrets", "dockerRegistry"],
  "properties": {
    "imageRegistry": {
      "type": "string",
      "default": "docker.io",
      "description": "Container registry prefix (defaults to 'docker.io')"
    },
    "jobsManager": {
      "type": "object",
      "required": ["tag", "env"],
      "properties": {
        "tag": {
          "type": "string",
          "description": "Docker image tag for jobs-manager, pods-monitor, and resource-monitor"
        },
        "env": {
          "type": "object",
          "required": ["CLIENT_ID"],
          "properties": {
            "CLIENT_ID": {
              "type": "string",
              "minLength": 1,
              "description": "Client ID for authentication"
            },
            "CLIENT_ENV": {
              "type": "string",
              "description": "Environment identifier (dev, staging, prod)"
            },
            "HTTP_PROXY_HOST": { "type": "string" },
            "HTTP_PROXY_PORT": { "type": "string" },
            "HTTP_PROXY_USERNAME": { "type": "string" },
            "HTTP_PROXY_PASSWORD": { "type": "string" },
            "RESOURCE_REQUESTS": {
              "type": "string",
              "pattern": "^(cpu=\\S+,memory=\\S+)?$",
              "description": "Resource requests for spawned jobs (e.g. 'cpu=2,memory=8Gi')"
            },
            "RESOURCE_LIMITS": {
              "type": "string",
              "pattern": "^(cpu=\\S+,memory=\\S+)?$",
              "description": "Resource limits for spawned jobs"
            },
            "GPU_REQUESTS": { "type": "string" },
            "GPU_LIMITS": { "type": "string" },
            "RUNTIME_CLASS_NAME": { "type": "string" }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "storageClass": {
      "type": "object",
      "required": ["create", "name"],
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Set to false to use an existing StorageClass"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the StorageClass"
        },
        "provisioner": {
          "type": "string",
          "description": "CSI provisioner (required when create is true)"
        },
        "allowVolumeExpansion": {
          "type": "boolean"
        },
        "volumeBindingMode": {
          "type": "string",
          "enum": ["", "Immediate", "WaitForFirstConsumer"]
        },
        "reclaimPolicy": {
          "type": "string",
          "enum": ["", "Delete", "Retain"]
        },
        "mountOptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "hostPath": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable hostPath PVs (bare-metal only)"
        },
        "dataPath": {
          "type": "string",
          "description": "Host path for shared data volume"
        },
        "logsPath": {
          "type": "string",
          "description": "Host path for logs volume"
        },
        "mysqlPath": {
          "type": "string",
          "description": "Host path for MySQL data volume"
        },
        "initJob": {
          "type": "boolean",
          "description": "Create pre-install Job to set up host directories"
        }
      },
      "if": {
        "properties": { "enabled": { "const": true } }
      },
      "then": {
        "required": ["dataPath", "logsPath", "mysqlPath"],
        "properties": {
          "dataPath": { "minLength": 1 },
          "logsPath": { "minLength": 1 },
          "mysqlPath": { "minLength": 1 }
        }
      }
    },
    "pvcAccessMode": {
      "type": "string",
      "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"],
      "description": "Access mode for PVCs"
    },
    "clientData": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "PVC name for shared data"
        },
        "storage": {
          "type": "string",
          "description": "Storage size (e.g. '50Gi')"
        }
      }
    },
    "clientLogsPvc": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "PVC name for logs"
        },
        "storage": {
          "type": "string",
          "description": "Storage size (e.g. '10Gi')"
        }
      }
    },
    "mysqlPvc": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "PVC name for MySQL data"
        },
        "storage": {
          "type": "string",
          "description": "Storage size (e.g. '2Gi')"
        }
      }
    },
    "mysql": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "MySQL deployment and service name"
        }
      }
    },
    "clusterRole": {
      "type": "object",
      "required": ["create", "name"],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "useClusterScope": {
          "type": "boolean",
          "description": "Use ClusterRole (true) or namespace-scoped Role (false)"
        }
      }
    },
    "resourceMonitor": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy resource-monitor DaemonSet"
        }
      }
    },
    "openshift": {
      "type": "object",
      "properties": {
        "scc": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create SecurityContextConstraints for resource monitor"
            }
          }
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Node selector labels for jobs-manager and MySQL pods"
    },
    "secrets": {
      "type": "object",
      "required": ["create", "clientPassword"],
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create the Kubernetes Secret (set false to use existing)"
        },
        "clientPassword": {
          "type": "string",
          "minLength": 1,
          "description": "Client authentication password"
        }
      }
    },
    "dockerRegistry": {
      "type": "object",
      "required": ["create"],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "server": {
          "type": "string",
          "format": "uri"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      },
      "if": {
        "properties": { "create": { "const": true } }
      },
      "then": {
        "required": ["create", "server", "username", "password", "email"],
        "properties": {
          "username": { "minLength": 1 },
          "password": { "minLength": 1 },
          "email": { "minLength": 1 }
        }
      }
    }
  }
}
