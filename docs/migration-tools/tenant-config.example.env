# =============================================================================
#  tenant-config.example.env — copy to tenant-config.env (gitignored), fill
#  in real values, then run ./generate.sh.
#
#  How to populate
#  ----------------
#  For each tenant the migration script needs:
#    - The Helm release name (NOT always the namespace name; charite's
#      release is "tracebloc")
#    - The tenant namespace
#    - The tenant's CLIENT_ID + CLIENT_PASSWORD (from the old release values)
#    - The tenant's StorageClass name (typically `<tenant>-awsefs`)
#    - The 3 PV IDs that the existing PVCs are bound to
#
#  Survey commands
#  ---------------
#  CTX=arn:aws:eks:eu-central-1:872515254613:cluster/tracebloc-clients-prod
#
#  # Release name + chart version
#  helm --kube-context "$CTX" list -n <namespace>
#
#  # Old values — CLIENT_ID, CLIENT_PASSWORD live in here
#  helm --kube-context "$CTX" get values <release> -n <namespace>
#
#  # PV IDs per PVC
#  kubectl --kube-context "$CTX" get pvc -n <namespace> \
#    -o custom-columns="PVC:.metadata.name,PV:.spec.volumeName,SIZE:.spec.resources.requests.storage"
#
#  # Confirm reclaim policy is Retain (mandatory — Option C relies on it)
#  kubectl --kube-context "$CTX" get pv <pv> \
#    -o custom-columns="PV:.metadata.name,RECLAIM:.spec.persistentVolumeReclaimPolicy,STATUS:.status.phase"
#
#  Format
#  ------
#  TENANTS is a newline-separated list. Each line is pipe-delimited:
#    <tenant>|<release>|<namespace>|<CLIENT_ID>|<CLIENT_PASSWORD>|<sc-name>|<pv-mysql>|<pv-logs>|<pv-data>
#
#  Lines starting with `#` are ignored. Empty lines are ignored.
# =============================================================================

# Shared across all tenants (fill in real values, keep local)
DOCKER_USERNAME=lukastracebloc
DOCKER_PASSWORD=__DOCKER_HUB_PERSONAL_ACCESS_TOKEN__
DOCKER_EMAIL=lukas@tracebloc.io
EFS_FS=fs-06b3faf51675ff9f9
RESOURCE_REQUESTS=cpu=2,memory=8Gi
RESOURCE_LIMITS=cpu=8,memory=20Gi

# mysql root password baked into the tracebloc/mysql-client image. mysqldump
# needs it during Phase 1. Keep it out of git — set here or via the
# MYSQL_ROOT_PW env var when running migrate-tenant.sh.
MYSQL_ROOT_PW=__LEGACY_MYSQL_ROOT_PW__

# Per-tenant rows. Replace the placeholders with real values from the survey
# commands above. Use real PV IDs for each tenant on this cluster.
TENANTS="
bmw     | bmw       | bmw     | __BMW_CLIENT_ID__     | __BMW_CLIENT_PASSWORD__     | bmw-awsefs     | __BMW_PV_MYSQL__     | __BMW_PV_LOGS__     | __BMW_PV_DATA__
cisco   | cisco     | cisco   | __CISCO_CLIENT_ID__   | __CISCO_CLIENT_PASSWORD__   | cisco-awsefs   | __CISCO_PV_MYSQL__   | __CISCO_PV_LOGS__   | __CISCO_PV_DATA__
charite | tracebloc | charite | __CHARITE_CLIENT_ID__ | __CHARITE_CLIENT_PASSWORD__ | charite-awsefs | __CHARITE_PV_MYSQL__ | __CHARITE_PV_LOGS__ | __CHARITE_PV_DATA__
"
